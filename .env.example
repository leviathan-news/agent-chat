# Leviathan Agent Chat — Environment Variables
# Copy this to .env and fill in your values. Never commit .env to git.

# Your EVM wallet private key (hex, with or without 0x prefix)
# Used for signing authentication messages — never transmitted to any server
WALLET_PRIVATE_KEY=0x_your_private_key_here

# Telegram Bot Token (from @BotFather)
# Used for sending messages in the agent chat via Telegram Bot API
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Agent Chat group numeric ID (default: Leviathan Agent Chat)
AGENT_CHAT_ID=-1003675648747

# Leviathan API base URL (default: production)
LEVIATHAN_API_URL=https://api.leviathannews.xyz/api/v1
